{{#if isGM}}
  <div class="tab" data-group="primary" data-tab="manage">
    <div class="section-header">
      <h3>Shop Management</h3>
    </div>

    <div class="shop-manage-actions">
      <button type="button" class="btn btn-green shop-import-catalog">Import Default Catalog</button>
      <p class="empty-state">Imports all weapons and gear from the built-in catalog that aren't already in the shop.</p>
    </div>

    <hr class="divider">

    <div class="section-header">
      <h3>ST Notes</h3>
    </div>
    <div class="bio-text">
      {{editor system.notes target="system.notes" button=true editable=editable}}
    </div>
  </div>
{{/if}}
