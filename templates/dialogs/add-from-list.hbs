<form>
  <div class="form-group">
    <label>{{label}}</label>
    <select name="selection">
      {{#each options}}
        <option value="{{this.value}}">{{this.label}}</option>
      {{/each}}
    </select>
  </div>
  {{#if showRating}}
    <div class="form-group">
      <label>Rating</label>
      <input type="number" name="rating" value="1" min="1" max="5" />
    </div>
  {{/if}}
</form>
