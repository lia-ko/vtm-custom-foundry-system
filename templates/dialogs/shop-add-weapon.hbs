<form>
  <div class="form-group"><label>Name</label><input type="text" name="name" autofocus /></div>
  <div class="form-group">
    <label>Type</label>
    <select name="type">
      <option>Melee</option>
      <option>Ranged</option>
      <option>Thrown</option>
    </select>
  </div>
  <div class="form-group"><label>Attribute</label><input type="text" name="attribute" value="dexterity" /></div>
  <div class="form-group"><label>Skill</label><input type="text" name="skill" value="melee" /></div>
  <div class="form-group"><label>Price ($)</label><input type="number" name="price" value="100" min="0" /></div>
  <div class="form-group"><label>Description</label><input type="text" name="desc" /></div>
  <div class="form-group"><label>Stock (-1 = unlimited)</label><input type="number" name="stock" value="-1" min="-1" /></div>
</form>
